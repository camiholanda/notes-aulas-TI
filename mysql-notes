SET GLOBAL log_bin_trust_function_creators = 1;

DELIMITER //
CREATE FUNCTION fn_crescimento_populacional(
    p_ano_inicial INT,
    p_ano_final INT,
    p_cod_municipio INT
)
RETURNS INT

BEGIN
    DECLARE v_pop_inicial INT DEFAULT 0;
    DECLARE v_pop_final INT DEFAULT 0;
    DECLARE v_crescimento INT;

    SELECT populacao INTO v_pop_inicial
    FROM censo
    WHERE cod_mun = p_cod_municipio
    AND ano = p_ano_inicial;

	SELECT populacao INTO v_pop_final
    FROM censo
    WHERE cod_mun = p_cod_municipio
    AND ano = p_ano_final;

    SET v_crescimento = v_pop_final - v_pop_inicial;

    RETURN v_crescimento;
END //
DELIMITER ;

SELECT fn_crescimento_populacional(2012, 2011, 19) AS crescimento;


