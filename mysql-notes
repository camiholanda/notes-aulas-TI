delimiter $$

create function fn_initcap(nome varchar (50))

returns varchar(50)

begin
	upper(substring(nome, 1, 1))
	lower(substring(nome, 2, 50))

	return concat(upper(substring(nome, 1, 1)),
		      lower(substring(nome, 2, 50))
		      );
end $$
delimiter ;

